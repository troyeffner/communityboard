{
  "name": "communityboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test tests/regression/*.test.mjs",
    "test:e2e": "npx playwright test",
    "snap:browse": "node scripts/manual-snap-browse.mjs",
    "test:regression": "npm run test && npm run lint && npm run build && npm run test:e2e",
    "verify:guardrails": "npm run test && npm run lint && npm run build && npm run test:e2e",
    "eval:snap": "node scripts/ui-eval-snap.mjs",
    "eval:diff": "node scripts/ui-eval-diff.mjs",
    "eval:report": "node scripts/ui-eval-report.mjs",
    "eval:ui": "node scripts/ui-eval-snap.mjs && node scripts/ui-eval-diff.mjs && node scripts/ui-eval-report.mjs",
    "trunk:overnight": "node trunk/overnight/jobs/nightly-growth-pass1.mjs",
    "trunk:overnight:pass2": "node trunk/overnight/jobs/nightly-growth-pass2.mjs",
    "trunk:readmodels": "node trunk/overnight/jobs/generate-interaction-readmodels-pass1.mjs",
    "trunk:parity": "node trunk/overnight/jobs/parity-interaction-readmodels-pass1.mjs",
    "trunk:content-readmodels": "node trunk/overnight/jobs/generate-content-readmodels-pass1.mjs",
    "trunk:content-parity": "node trunk/overnight/jobs/parity-content-readmodels-pass1.mjs",
    "trunk:deploy:readmodels": "node trunk/overnight/jobs/generate-deploy-readmodels-pass1.mjs",
    "trunk:route-parity": "node trunk/overnight/jobs/emit-route-parity-summary-pass4.mjs",
    "trunk:frontmatter:report": "node trunk/overnight/jobs/report-frontmatter-coverage-pass1.mjs",
    "trunk:deploy:intent": "node trunk/branches/ops/emit-deploy-fiber.mjs --stage intent --status planned",
    "trunk:deploy:result": "node trunk/branches/ops/emit-deploy-fiber.mjs --stage result --status success",
    "trunk:deploy:rollback": "node trunk/branches/ops/emit-deploy-fiber.mjs --stage rollback --status executed",
    "trunk:ether:ingest": "node trunk/overnight/jobs/ingest-ether-timelines-pass1.mjs",
    "trunk:ether:lint-sources": "node trunk/overnight/jobs/lint-ether-sources-pass1.mjs",
    "trunk:pass3": "npm run trunk:overnight && npm run trunk:readmodels && npm run trunk:parity",
    "trunk:pass4": "npm run trunk:pass3 && npm run trunk:route-parity",
    "trunk:pass5": "npm run trunk:overnight:pass2 && npm run trunk:parity && npm run trunk:content-readmodels && npm run trunk:content-parity && npm run trunk:deploy:readmodels && npm run trunk:ether:lint-sources && npm run trunk:route-parity && npm run trunk:frontmatter:report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/analytics": "^1.6.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
