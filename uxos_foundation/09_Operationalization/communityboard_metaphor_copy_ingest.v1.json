    {
      "id": "issue_cb_001",
      "issue_type": "copy_ooux_mismatch",
      "severity": "blocking",
      "detected_by": "manual",
      "from_entity_id": "copy_cb_004",
      "to_entity_id": "obj_seen_at",
      "summary": "Seen-at vocabulary contract is broken by mixed `Found at` and `Seen at` copy across create, submit, poster, and manage pages.",
      "details": "Canonical field is poster_uploads.seen_at_name, but public and builder copy still mixes names and user intent.",
      "suggested_fix": "Standardize display term to `Seen at` while keeping DB field unchanged.",
      "status": "open",
      "version_id": "cb_ooux_v1",
      "timestamps": {
        "created_at": "2026-02-28T00:00:00Z",
        "updated_at": "2026-02-28T00:00:00Z"
      }
    },
